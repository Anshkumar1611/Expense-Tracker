# Copy to .env and adjust as needed (local dev defaults shown)
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# --- Production (set these on your backend host: Render / Railway / Fly) ---
# JWT_SECRET     -> a long random string (e.g. `openssl rand -hex 32`)
# CLIENT_ORIGIN  -> your deployed frontend URL, e.g. https://expense-tracker.vercel.app
# DATABASE_PATH  -> absolute path on a PERSISTENT disk, e.g. /data/data.db
#                   (without a persistent disk, SQLite data is wiped on every redeploy)
# PORT           -> usually injected by the host; the app already reads process.env.PORT
