# Frontend build-time config.
#
# Local dev: leave VITE_API_URL empty — the Vite dev proxy (vite.config.js)
# forwards /api to http://localhost:4000.
#
# Production (set this in the Vercel project's Environment Variables):
# VITE_API_URL = the deployed backend origin, NO trailing /api and NO trailing slash
#   e.g. https://expense-tracker-api.onrender.com
VITE_API_URL=
